# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit secrets
.env
.env.local
.env.production
.env.development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# WhatsApp session auth — contains account credentials, NEVER commit
.whatsapp-auth/

# Server-side local data store
.norla-data/

# Android signing keystore — ⚠️ NEVER commit. Back up separately!
*.keystore
*.jks

# Generated Play Store assets (not needed in repo)
play-store-icon-512.png
play-store-feature-graphic.png

# Android build outputs
android/app/build/
android/.gradle/
android/app/.cxx/

# Capacitor generated
android/app/src/main/assets/public/
