{
  "name": "norla-admin",
  "version": "1.0.0",
  "description": "Norla Admin Panel — Desktop Server Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build-dir": "electron-builder --win --dir"
  },
  "author": "Norla Team",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.norla.admin",
    "productName": "Norla Admin",
    "win": {
      "target": "portable",
      "icon": "../LOGO/Norla_with_bg_logo.png"
    },
    "files": [
      "main.js",
      "splash.html",
      "error.html"
    ],
    "extraResources": [
      {
        "from": "../LOGO/Norla_with_bg_logo.png",
        "to": "icon.png"
      }
    ]
  }
}
