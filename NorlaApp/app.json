{
  "expo": {
    "name": "Norla",
    "slug": "norla",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "norla",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.norla.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Norla needs camera access to capture photos for nutrition analysis",
        "NSPhotoLibraryUsageDescription": "Norla needs photo library access to select images for analysis"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.norla.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-splash-screen",
      [
        "expo-camera",
        {
          "cameraPermission": "Norla needs camera access to capture photos for nutrition analysis"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Norla needs photo library access to select images for analysis"
        }
      ],
      "expo-font",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "de34530d-46e3-423d-bdff-204eb72e5f2b"
      }
    },
    "owner": "norlaapp"
  }
}
